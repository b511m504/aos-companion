  "engines": {
    "node": ">=18 <21",
    "npm": ">=9"
  },
  "type": "commonjs",
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "playwright": "^1.59.1",
    "xml2js": "^0.6.2"
  },
